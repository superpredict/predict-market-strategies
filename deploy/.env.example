# ── Authentication ────────────────────────────────────────────────────────────
# Ethereum wallet private key (required when DRY_RUN=false)
PRIVATE_KEY=0x...

# ── Trading Mode ──────────────────────────────────────────────────────────────
# Set to false for live trading; true (default) logs actions without placing orders
DRY_RUN=true

# All other parameters (position size, edge threshold, exposure cap, confidence
# threshold, etc.) are static constants defined in takerbot/config/constants.ts.
# Market-specific values (market ID, token ID, strike, expiry) are passed as
# CLI arguments when starting each process — see README for details.
